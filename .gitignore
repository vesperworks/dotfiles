# Private data (local only)
.brain/

# Secrets
zsh/.secrets.zsh

# Machine-local overrides (not tracked — see *.local.example for templates)
zsh/.zshrc.local
tmux/.config/tmux/tmux.conf.local

# macOS
.DS_Store
.localized

# Editor
*.swp
*.swo
*~

# Backup
*.bak.*

# Claude Code local
**/.claude/
!claude/.claude/
claude/.claude/settings.local.json
claude/.claude/projects/
claude/.claude/todos/
claude/.claude/plans/
claude/.claude/eval/**/results/

# Codex local
codex/.codex/sessions/
codex/.codex/archived_sessions/
codex/.codex/log/
codex/.codex/auth.json
codex/.codex/history.jsonl
codex/.codex/version.json
codex/.codex/skills/.system/
codex/.codex/skills/vercel-react-best-practices/

# Plugins (managed by plugin managers)
tmux/.config/tmux/plugins/
yazi/.config/yazi/plugins/

# aerospace layouts (contain window titles with personal info)
aerospace/.config/aerospace/layouts*.json

# nvim (managed by lazy.nvim / personal notes)
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/**/lazy/*
nvim/.config/nvim/PRPs/
nvim/.config/nvim/thoughts/
nvim/.config/nvim/logs.md
nvim/.config/nvim/logcompact.md
nvim/.config/nvim/tmp/
nvim/.config/nvim/CLAUDE.md
nvim/.config/nvim/CONTINUITY.md
nvim/.config/nvim/vscode-alt-move-keybindings.json

# Application credentials
.config/gh/hosts.yml
.config/gcloud/

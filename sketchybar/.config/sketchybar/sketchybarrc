# SketchyBar Configuration
# Inspired by FelixKratz/dotfiles
# https://github.com/FelixKratz/dotfiles

export CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"

# =============================================================================
# Load Color Scheme (Catppuccin Macchiato - FelixKratz style)
# =============================================================================
source "$CONFIG_DIR/colors.sh"

##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

sketchybar --bar position=top \
                 height=39 \
                 blur_radius=0 \
                 color=$TRANSPARENT \
                 corner_radius=0 \
                 margin=8 \
                 y_offset=0 \
                 shadow=off \
                 display=all \
                 topmost=window

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:16.0"
  label.font="Hack Nerd Font:Bold:13.0"
  icon.color=$ICON_COLOR
  label.color=$LABEL_COLOR
  icon.padding_left=8
  icon.padding_right=6
  label.padding_left=6
  label.padding_right=8
  background.color=$BACKGROUND_1
  background.corner_radius=5
  background.height=26
)
sketchybar --default "${default[@]}"

##### Adding AeroSpace Workspace Indicators #####
# AeroSpace workspaces (replaces Mission Control spaces)
# https://nikitabobko.github.io/AeroSpace/guide
# Animation inspired by FelixKratz/dotfiles

# Define workspaces (1-9 and 0)
WORKSPACES=("1" "2" "3" "4" "5" "Q" "W" "E" "R" "T")

for workspace in "${WORKSPACES[@]}"; do
  # Space item (inner border)
  space=(
    icon="$workspace"
    icon.padding_left=12
    icon.padding_right=8
    icon.highlight_color=$MAGENTA
    background.color=$BLACK
    background.border_width=1
    background.border_color=$BLACK
    background.corner_radius=5
    background.height=26
    background.drawing=off
    label.drawing=on
    label.font="sketchybar-app-font:Regular:14.0"
    label.color=$APP_ICON_COLOR
    label.padding_right=12
    script="$PLUGIN_DIR/aerospace.sh"
    click_script="aerospace workspace $workspace"
  )
  sketchybar --add item "space.$workspace" left --set "space.$workspace" "${space[@]}"

  # Bracket (outer border) for double border effect
  sketchybar --add bracket "space_bracket.$workspace" "space.$workspace" \
             --set "space_bracket.$workspace" \
                   background.color=$TRANSPARENT \
                   background.border_color=$BACKGROUND_2 \
                   background.border_width=1 \
                   background.corner_radius=5 \
                   background.height=26 \
                   background.drawing=off
done

# Subscribe to aerospace workspace changes
sketchybar --add event aerospace_workspace_change
for ws in "${WORKSPACES[@]}"; do
  sketchybar --subscribe "space.$ws" aerospace_workspace_change
done

##### Adding Left Items #####
# We add some regular items to the left side of the bar, where
# only the properties deviating from the current defaults need to be set

sketchybar --add item chevron left \
           --set chevron icon=">" label.drawing=off icon.color=$BACKGROUND_1 icon.font="Hack Nerd Font:Bold:18.0" background.drawing=off \
           --add item front_app left \
           --set front_app icon.font="sketchybar-app-font:Regular:16.0" \
                           icon.color=$WHITE \
                           script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Clock
sketchybar --add item clock right \
           --set clock update_freq=10 \
                       padding_left=6 \
                       padding_right=6 \
                       icon.drawing=off \
                       script="$PLUGIN_DIR/clock.sh"

# IME/Keyboard Layout (A / あ)
sketchybar --add item keyboard right \
           --set keyboard padding_left=6 \
                          padding_right=6 \
                          icon.drawing=off \
                          label.color=$WHITE \
                          script="$PLUGIN_DIR/keyboard.sh" \
           --add event keyboard_change "AppleSelectedInputSourcesChangedNotification" \
           --subscribe keyboard keyboard_change

# Volume (icon only - click for details popup)
sketchybar --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
                        update_freq=0 \
                        padding_left=6 \
                        padding_right=6 \
                        icon=󰕾 \
                        icon.color=$GREEN \
                        icon.padding_right=6 \
                        label.drawing=off \
                        popup.background.color=$BACKGROUND \
                        popup.background.corner_radius=10 \
                        popup.background.border_width=1 \
                        popup.background.border_color=$SURFACE1 \
                        popup.blur_radius=50 \
           --subscribe volume volume_change mouse.clicked mouse.exited.global

for i in 1 2; do
  sketchybar --add item "volume.$i" popup.volume \
             --set "volume.$i" \
                   icon.font="Hack Nerd Font:Bold:13.0" \
                   icon.color=$WHITE \
                   icon.padding_left=8 \
                   icon.padding_right=4 \
                   label.font="Hack Nerd Font:Regular:13.0" \
                   label.color=$WHITE \
                   label.padding_right=8 \
                   background.color=$TRANSPARENT \
                   background.corner_radius=0 \
                   background.height=24
done

# Battery (icon only - click for details popup)
sketchybar --add item battery right \
           --set battery update_freq=120 \
                         padding_left=6 \
                         padding_right=6 \
                         icon.font="SF Pro:Regular:18.0" \
                         label.drawing=off \
                         popup.background.color=$BACKGROUND \
                         popup.background.corner_radius=10 \
                         popup.background.border_width=1 \
                         popup.background.border_color=$SURFACE1 \
                         popup.blur_radius=50 \
                         script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change mouse.clicked mouse.exited.global

for i in 1 2 3; do
  sketchybar --add item "battery.$i" popup.battery \
             --set "battery.$i" \
                   icon.font="Hack Nerd Font:Bold:13.0" \
                   icon.color=$WHITE \
                   icon.padding_left=8 \
                   icon.padding_right=4 \
                   label.font="Hack Nerd Font:Regular:13.0" \
                   label.color=$WHITE \
                   label.padding_right=8 \

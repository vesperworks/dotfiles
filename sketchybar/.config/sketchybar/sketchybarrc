##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update

# codex_usage uses update_freq=120 to reduce CLI calls, so the first render
# would otherwise be delayed. Re-assigning the script after the bar finishes
# (re)loading forces a SENDER=forced run. Detached via nohup+disown so it
# survives the restart of the sketchybar process.
nohup bash -c "sleep 2 && sketchybar --set codex_usage script='$PLUGIN_DIR/codex_usage.sh'" >/dev/null 2>&1 &
disown

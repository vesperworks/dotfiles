# ~/.config/tmux/tmux.conf.local — Machine-specific overrides (not tracked by git)
# Copy this file to ~/.config/tmux/tmux.conf.local and customize for your machine.
#
# Load order:  tmux.conf (plugins, status-right) → tmux.conf.local
# This file is sourced LAST, so any 'set' here overwrites the defaults.
# Same option name = last write wins.
#
# Usage:
#   cp ~/dotfiles/tmux/.config/tmux/tmux.conf.local.example ~/.config/tmux/tmux.conf.local
#   vim ~/.config/tmux/tmux.conf.local

# --- Tokyo Night theme variant ---
# Available: night (default), storm, day, moon
# set -g @tokyo-night-tmux_theme 'storm'

# --- Status bar color override ---
# set -g status-style 'bg=#1a1b26 fg=#c0caf5'

# --- Window status colors ---
# Active window: highlight color
# set -g window-status-current-style 'fg=#7aa2f7,bold'
# Inactive window
# set -g window-status-style 'fg=#565f89'

# --- Pane border colors ---
# set -g pane-active-border-style 'fg=#7aa2f7'
# set -g pane-border-style 'fg=#3b4261'

# --- Zen Mode target width ---
# prefix + Z で左右に空ペインを挟んで中央寄せ。マシンの解像度に合わせて調整
# set -g @zen-target-width 120

# --- Zen Mode auto-toggle ---
# ウィンドウ幅で自動 ON/OFF。off にすると prefix + Z だけで動く
# set -g @zen-auto off
# しきい値（既定: target+60 で ON / target+20 で OFF。ヒステリシス）
# set -g @zen-auto-on-width 180
# set -g @zen-auto-off-width 130

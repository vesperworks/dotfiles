{
  "cleanupPeriodDays": 90,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(.tmp/**)",
      "Write(~/Works/**)",
      "Edit(src/**)",
      "Edit(docs/**)",
      "Edit(~/Works/**)",
      "MultiEdit",
      "LS",
      "Grep",
      "Glob",
      "TodoRead",
      "TodoWrite",
      "NotebookRead",
      "NotebookEdit",
      "Task",
      "ExitPlanMode",
      "Skill(*)",
      "SlashCommand(*)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:docs.npmjs.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:bun.sh)",
      "WebFetch(domain:tauri.app)",
      "WebFetch(domain:mastra.ai)",
      "WebFetch(domain:dify.ai)",
      "WebFetch(domain:n8n.io)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:neovim.io)",
      "WebFetch(domain:nikitabobko.github.io)",
      "WebFetch(domain:felixkratz.github.io)",
      "WebFetch(domain:catppuccin.com)",
      "WebFetch(domain:eu-central-1-1.aws.cloud2.influxdata.com)",
      "mcp__ide__*",
      "mcp__context7__*",
      "mcp__pencil",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__select_page",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__close_page",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__hover",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__press_key",
      "mcp__chrome-devtools__fill_form",
      "mcp__chrome-devtools__type_text",
      "mcp__chrome-devtools__resize_page",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__get_console_message",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__handle_dialog",
      "mcp__chrome-devtools__upload_file",
      "mcp__chrome-devtools__emulate",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "Bash(jj *)",
      "Bash(source ~/.claude/scripts/:*)",
      "Bash(~/.claude/scripts/:*)",
      "Bash(gh issue:*)",
      "Bash(gh project:*)",
      "Bash(gh api graphql:*)",
      "Bash(search-sessions:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r *)",
      "Bash(rm *)",
      "Bash(dd:*)",
      "Bash(format:*)",
      "Bash(fdisk:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git force:*)",
      "Bash(git push --force:*)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git stash drop *)",
      "Bash(jj abandon *)",
      "Bash(jj workspace forget *)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(.git/config)",
      "Read(node_modules/**)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(id_ecdsa)",
      "Read(*.pem)",
      "Read(*.key)",
      "Write(.env*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(gh pr merge:*)",
      "Bash(jj git push:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(sed:*)",
      "Bash(export:*)",
      "Bash(tmux split-window:*)",
      "Bash(bun remove:*)",
      "Bash(deno uninstall:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm rm:*)",
      "mcp__puppeteer__*"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-send-notification.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/remove-index-lock.sh",
            "if": "Bash(jj *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/remove-index-lock.sh",
            "if": "Bash(git *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-commands.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-message-lint.sh",
            "if": "Bash(git commit *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-message-lint.sh",
            "if": "Bash(jj commit *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-message-lint.sh",
            "if": "Bash(jj split *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-message-lint.sh",
            "if": "Bash(jj describe *)"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/command-logger.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-lint.sh",
            "if": "Bash(git commit *)",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-lint.sh",
            "if": "Bash(jj commit *)",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-lint.sh",
            "if": "Bash(jj split *)",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-lint.sh",
            "if": "Bash(jj describe *)",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-sensitive-check.sh",
            "if": "Bash(git commit *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-sensitive-check.sh",
            "if": "Bash(jj commit *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-sensitive-check.sh",
            "if": "Bash(jj split *)"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-sensitive-check.sh",
            "if": "Bash(jj describe *)"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-sensitive-files.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest"
  },
  "enabledPlugins": {
    "commit-commands@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "gh",
      "jj"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "advisorModel": "opus",
  "fastModePerSessionOptIn": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "preferredNotifChannel": "terminal_bell",
  "autoCompactEnabled": false,
  "teammateMode": "auto",
  "agentPushNotifEnabled": false,
  "tui": "fullscreen",
  "fileCheckpointingEnabled": true,
  "showThinkingSummaries": true,
  "autoMemoryEnabled": true,
  "inputNeededNotifEnabled": true,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": true,
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".cache"
    ]
  }
}

{
  "theme": "nord",
  "display": {
    "style": "minimal",
    "charset": "unicode",
    "padding": 1,
    "autoWrap": false,
    "lines": [
      {
        "segments": {
          "directory": { "enabled": true, "style": "fish" },
          "context": { "enabled": true, "displayStyle": "bar" },
          "session": { "enabled": true, "type": "tokens" }
        }
      },
      {
        "segments": {
          "git": { "enabled": true, "showSha": true },
          "model": { "enabled": true }
        }
      }
    ]
  }
}

#:schema https://developers.openai.com/codex/config-schema.json
# ~/.codex/config.toml (template)
#
# このファイルは公開可能な雛形（template）です。
# install.sh が ~/.codex/config.toml にコピーする想定。
# 個人マシン固有の値（trust list / 絶対パスを含む notify / marketplaces source 等）は
# 含めない。それらは codex CLI が起動時に自動追記する。
# 公開リポに乗らないように .gitignore で config.toml 自体は除外している。

# === ベースライン（安全デフォルト） ===
model = "gpt-5.5"
model_verbosity = "medium"    # 応答の冗長さ
approval_policy = "on-request" # 通常は自走、危険操作だけ承認
sandbox_mode = "workspace-write"    # ローカル作業を止まりにくくする
model_reasoning_effort = "medium"
model_reasoning_summary = "concise"  # 推論過程を簡潔に表示
personality = "pragmatic"
web_search = "live"
allow_login_shell = false

[sandbox_workspace_write]
network_access = false # 基本はネットワーク遮断
writable_roots = []    # 必要なら "~/.npm" などを追加

# === プロファイル（用途別に緩める） ===

# 依存インストールやWeb開発などで限定的に緩める
[profiles.web]
sandbox_mode = "workspace-write"
approval_policy = "on-request"   # モデルが必要と判断した時のみ承認要求
allow_login_shell = false
[profiles.web.sandbox_workspace_write]
network_access = true
writable_roots = ["~/.npm", "~/.cache/yarn", "~/.cache/uv", "~/.bun/install/cache"]

# 完全読み取り専用（安全）
[profiles.readonly]
approval_policy = "untrusted"
sandbox_mode = "read-only"
allow_login_shell = false

# 深い分析用（推論最大）
[profiles.deep]
model = "gpt-5.3-codex"
model_reasoning_effort = "xhigh"
model_reasoning_summary = "detailed"
sandbox_mode = "read-only"
approval_policy = "untrusted"
allow_login_shell = false

# 高速なローカル探索用。rules による allow を前提に承認を最小化する
[profiles.fast-explore]
approval_policy = "never"
sandbox_mode = "workspace-write"
allow_login_shell = false
[profiles.fast-explore.sandbox_workspace_write]
network_access = false
writable_roots = []

# === エディタ・通知など ===
file_opener = "vscode"

[tui]
# デスクトップ通知
notifications = ["agent-turn-complete", "approval-requested"]
status_line = ["model-with-reasoning", "context-remaining", "current-dir", "five-hour-limit"]

# === シェル環境の安全化 ===
[shell_environment_policy]
inherit = "core"
exclude = ["AWS_*", "AZURE_*", "*TOKEN*", "*SECRET*", "*KEY*"]

# === ツール機能 ===
[tools.web_search]
context_size = "medium"

# === MCP サーバー ===
[mcp_servers.chrome-devtools]
command = "npx"
args = ["chrome-devtools-mcp"]

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp@latest"]

# pencil は macOS デスクトップアプリ依存。インストールしていない環境では削除可。
[mcp_servers.pencil]
command = "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64"
args = ["--ws-port", "63922"]

[features]
multi_agent = true

# プラグイン enable（codex CLI 起動時に必要なものは自動補完される。
# 以下は当方で確認済みの構成。不要なら削除。）
[plugins."github@openai-curated"]
enabled = true

[plugins."browser-use@openai-bundled"]
enabled = true

[plugins."computer-use@openai-bundled"]
enabled = true

[plugins."documents@openai-primary-runtime"]
enabled = true

[plugins."spreadsheets@openai-primary-runtime"]
enabled = true

[plugins."presentations@openai-primary-runtime"]
enabled = true

# --------------------------------------------------------------------
# 以下は codex CLI が起動時に自動追記するため、template には含めない:
#   - notify (computer-use bundled plugin の絶対パス)
#   - [projects."<absolute path>"] trust_level = "trusted"
#   - [marketplaces.*] source = "/Users/.../..."  ← 絶対パス
# 個別プロジェクトでカスタマイズしたい設定は <project>/.codex/config.toml に
# 配置することを推奨（公式の 2 層分離設計）。
# --------------------------------------------------------------------
